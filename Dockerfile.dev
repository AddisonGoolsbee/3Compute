# Development image for the CS Room backend service.
# Copies docker CLI from the official image so the backend can spawn user containers.
FROM docker:27-cli AS docker-cli

FROM python:3.12-slim

# Mirror the prod host: create the csroom-container group (GID 995) and add
# www-data to it. Files inside /var/lib/csroom/{uploads,classrooms} are owned
# 999:995 by the container user; www-data needs 995 as a supplementary group
# to read/write them. Without this, backend writes into classroom assignments
# fail with EACCES, and files the backend creates end up 33:33 which the
# container user (999:995) can't edit via the terminal.
RUN groupadd -g 995 csroom-container \
 && usermod -a -G csroom-container www-data

COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker

WORKDIR /var/www/csroom
COPY backend/requirements.txt backend/requirements.txt
RUN pip install --no-cache-dir -r backend/requirements.txt
